@model OrderViewModel
@{
    ViewData["Title"] = $"Order #{Model.OrderNumber}";
}

<h1 class="mb-4">Order #@Model.OrderNumber</h1>
<p class="text-muted">Placed on @Model.OrderDate.ToString("g")</p>

<partial name="_OrderSummary" model="Model" />

<a asp-controller="Order" asp-action="Index" class="btn btn-secondary mt-3">Back to my orders</a>
