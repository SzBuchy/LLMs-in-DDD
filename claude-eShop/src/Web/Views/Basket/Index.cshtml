@model BasketViewModel
@{
    ViewData["Title"] = "Your Cart";
}

<h1 class="mb-4">Your Cart</h1>

@if (!Model.Items.Any())
{
    <p>Your cart is empty. <a asp-controller="Home" asp-action="Index">Continue shopping</a>.</p>
}
else
{
    <form asp-controller="Basket" asp-action="SetQuantities" method="post">
        <input type="hidden" name="basketId" value="@Model.Id" />
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Unit price</th>
                    <th>Quantity</th>
                    <th>Subtotal</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.ProductName</td>
                        <td>@item.UnitPrice.ToString("C")</td>
                        <td style="max-width:100px">
                            <input type="number" min="0" class="form-control"
                                   name="quantities[@item.Id]" value="@item.Quantity" />
                        </td>
                        <td>@((item.UnitPrice * item.Quantity).ToString("C"))</td>
                        <td>
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    formaction="@Url.Action("RemoveItem", "Basket", new { basketId = Model.Id, basketItemId = item.Id })">
                                Remove
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="d-flex justify-content-between align-items-center">
            <button type="submit" class="btn btn-secondary">Update quantities</button>
            <h4>Total: @Model.TotalPrice.ToString("C")</h4>
        </div>
    </form>

    <div class="mt-3">
        <a asp-controller="Order" asp-action="Checkout" class="btn btn-primary">Checkout</a>
    </div>
}
