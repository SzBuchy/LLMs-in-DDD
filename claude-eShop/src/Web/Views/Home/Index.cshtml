@model CatalogIndexViewModel
@{
    ViewData["Title"] = "Catalog";
}

<h1 class="mb-4">Products</h1>

<form asp-controller="Home" asp-action="Index" method="get" class="row g-2 mb-4">
    <div class="col-auto">
        <select name="brandId" class="form-select" asp-items="Model.Brands" asp-for="BrandFilterApplied"></select>
    </div>
    <div class="col-auto">
        <select name="typeId" class="form-select" asp-items="Model.Types" asp-for="TypesFilterApplied"></select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Filter</button>
    </div>
</form>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var item in Model.CatalogItems)
    {
        <div class="col">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">@item.Name</h5>
                    <p class="card-text text-muted">@item.CatalogBrandName &middot; @item.CatalogTypeName</p>
                    <p class="card-text">@item.Description</p>
                    <p class="card-text fw-bold">@item.Price.ToString("C")</p>
                    <form asp-controller="Basket" asp-action="AddToBasket" method="post">
                        <input type="hidden" name="catalogItemId" value="@item.Id" />
                        <button type="submit" class="btn btn-outline-primary">Add to cart</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@if (Model.PaginationInfo.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination">
            @for (var i = 0; i < Model.PaginationInfo.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PaginationInfo.ActualPage ? "active" : "")">
                    <a class="page-link" asp-controller="Home" asp-action="Index"
                       asp-route-pageIndex="@i"
                       asp-route-brandId="@Model.BrandFilterApplied"
                       asp-route-typeId="@Model.TypesFilterApplied">@(i + 1)</a>
                </li>
            }
        </ul>
    </nav>
}
