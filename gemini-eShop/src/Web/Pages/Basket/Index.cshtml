@page
@model IndexModel
@{
    ViewData["Title"] = "Basket";
}

<div class="container my-5">
    <h2 class="mb-4 text-white">Shopping Cart</h2>

    @if (Model.BasketModel.Items.Any())
    {
        <form method="post" asp-page-handler="Update">
            <div class="table-responsive esh-basket-table-wrapper p-4 mb-4">
                <table class="table table-dark table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Description</th>
                            <th>Unit Price</th>
                            <th style="width: 120px;">Quantity</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.BasketModel.Items.Count; i++)
                        {
                            var item = Model.BasketModel.Items[i];
                            <tr>
                                <td>
                                    <img src="@item.PictureUri" alt="@item.ProductName" class="img-thumbnail esh-basket-thumbnail" />
                                </td>
                                <td>
                                    <h5 class="text-white mb-0">@item.ProductName</h5>
                                </td>
                                <td>@item.UnitPrice.ToString("C")</td>
                                <td>
                                    <input type="hidden" name="items[@i].Key" value="@item.CatalogItemId" />
                                    <input type="number" name="items[@i].Value" value="@item.Quantity" min="0" class="form-control bg-dark text-white border-secondary text-center" />
                                </td>
                                <td class="text-end fw-bold text-gradient">@((item.UnitPrice * item.Quantity).ToString("C"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="row align-items-center">
                <div class="col-md-6 mb-3 mb-md-0">
                    <a asp-page="/Index" class="btn btn-outline-light px-4">Continue Shopping</a>
                    <button type="submit" class="btn btn-secondary px-4 ms-2">Update Cart</button>
                </div>
                <div class="col-md-6 text-md-end">
                    <div class="d-inline-block text-start p-4 bg-dark border border-secondary rounded w-100 esh-checkout-box-card">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="text-secondary fs-5">Total price:</span>
                            <span class="text-white fs-3 fw-bold text-gradient">@Model.BasketModel.Total().ToString("C")</span>
                        </div>
                        <button type="submit" asp-page-handler="Checkout" class="btn btn-primary w-100 fs-5 py-2">Proceed to Checkout</button>
                    </div>
                </div>
            </div>
        </form>
    }
    else
    {
        <div class="text-center py-5 bg-dark border border-secondary rounded p-4">
            <h3 class="text-white mb-3">Your cart is empty</h3>
            <p class="text-secondary mb-4">Go back to the catalog to find items you want to buy.</p>
            <a asp-page="/Index" class="btn btn-primary px-5 py-2">Explore Products</a>
        </div>
    }
</div>
