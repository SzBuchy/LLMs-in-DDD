@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="container my-5 d-flex justify-content-center text-white">
    <div class="card bg-dark border-secondary p-5 esh-auth-card" style="width: 100%; max-width: 500px;">
        <h2 class="text-center mb-4">Register</h2>
        <form method="post" asp-route-returnUrl="@Model.ReturnUrl">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label"></label>
                <input asp-for="Input.Email" class="form-control bg-dark text-white border-secondary" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label"></label>
                <input asp-for="Input.Password" class="form-control bg-dark text-white border-secondary" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            
            <div class="mb-4">
                <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                <input asp-for="Input.ConfirmPassword" class="form-control bg-dark text-white border-secondary" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>
            
            <button type="submit" class="btn btn-primary w-100 py-2 fs-5 mb-3">Register</button>
        </form>
        
        <div class="text-center mt-3">
            <p class="text-secondary mb-0">Already have an account? <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-primary text-decoration-none">Log In</a></p>
        </div>
    </div>
</div>
