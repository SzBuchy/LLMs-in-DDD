@page
@model IndexModel
@{
    ViewData["Title"] = "Catalog";
}

<div class="esh-catalog-hero">
    <div class="container text-center text-md-start">
        <h1>eShopOnWeb</h1>
        <p>A reference application demonstrating monolithic Clean Architecture with ASP.NET Core.</p>
    </div>
</div>

<div class="container my-5">
    <form method="get" class="esh-catalog-filter-bar mb-4 row g-3 align-items-end p-4">
        <div class="col-md-4">
            <label class="form-label" for="brand">Brand</label>
            <select asp-for="CatalogModel.BrandFilterApplied" name="brandFilterApplied" asp-items="Model.CatalogModel.Brands" class="form-select"></select>
        </div>
        <div class="col-md-4">
            <label class="form-label" for="type">Type</label>
            <select asp-for="CatalogModel.TypeFilterApplied" name="typeFilterApplied" asp-items="Model.CatalogModel.Types" class="form-select"></select>
        </div>
        <div class="col-md-4">
            <button type="submit" class="btn btn-primary w-100 esh-filter-btn">Filter Products</button>
        </div>
    </form>

    @if (Model.CatalogModel.CatalogItems.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var item in Model.CatalogModel.CatalogItems)
            {
                <div class="col">
                    <div class="card h-100 esh-product-card">
                        <div class="esh-card-img-wrapper">
                            <img src="@item.PictureUri" class="card-img-top esh-product-image" alt="@item.Name" />
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@item.Name</h5>
                            <p class="card-text fs-4 fw-bold text-gradient mb-3">@item.Price.ToString("C")</p>
                            <form method="post" class="mt-auto">
                                <input type="hidden" name="catalogItemId" value="@item.Id" />
                                <input type="hidden" name="price" value="@item.Price" />
                                <button type="submit" class="btn btn-success w-100 esh-add-to-cart-btn">
                                    🛒 Add To Cart
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>

        <nav aria-label="Page navigation" class="mt-5 d-flex justify-content-center">
            <ul class="pagination">
                <li class="page-item @(Model.CatalogModel.PaginationInfo.ActualPage == 0 ? "disabled" : "")">
                    <a class="page-link" asp-all-route-data='@new Dictionary<string, string> { { "brandFilterApplied", Model.CatalogModel.BrandFilterApplied?.ToString() ?? "" }, { "typeFilterApplied", Model.CatalogModel.TypeFilterApplied?.ToString() ?? "" }, { "pageId", (Model.CatalogModel.PaginationInfo.ActualPage - 1).ToString() } }'>Previous</a>
                </li>
                <li class="page-item disabled"><span class="page-link text-white bg-dark border-0">Page @(Model.CatalogModel.PaginationInfo.ActualPage + 1) of @Model.CatalogModel.PaginationInfo.TotalPages</span></li>
                <li class="page-item @((Model.CatalogModel.PaginationInfo.ActualPage + 1) >= Model.CatalogModel.PaginationInfo.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-all-route-data='@new Dictionary<string, string> { { "brandFilterApplied", Model.CatalogModel.BrandFilterApplied?.ToString() ?? "" }, { "typeFilterApplied", Model.CatalogModel.TypeFilterApplied?.ToString() ?? "" }, { "pageId", (Model.CatalogModel.PaginationInfo.ActualPage + 1).ToString() } }'>Next</a>
                </li>
            </ul>
        </nav>
    }
    else
    {
        <div class="text-center py-5">
            <h3>No products found</h3>
            <p>Try resetting the filters or adding products in the Admin page.</p>
        </div>
    }
</div>
