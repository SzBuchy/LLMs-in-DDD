{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Formatting.Compact",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Process",
      "Serilog.Enrichers.Thread"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithEnvironmentName",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ],
    "Properties": {
      "service.name": "basket-service"
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console",
              "Args": {
                "formatter": "Serilog.Formatting.Compact.RenderedCompactJsonFormatter, Serilog.Formatting.Compact"
              }
            }
          ]
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      },
      {
        "Name": "Http",
        "Args": {
          "requestUri": "http://localhost:8080",
          "queueLimitBytes": null,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },

  "OpenTelemetry": {
    "Service": {
      "Name": "flame.basket-service",
      "Version": "1.0.0",
      "Namespace": "flame",
      "InstanceId": ""
    },

    "Tracing": {
      "Enabled": true,

      "Sampling": {
        "Type": "ParentBasedTraceIdRatio",
        "Ratio": 1.0
      },

      "AspNetCore": {
        "RecordException": true,
        "Enrich": {
          "IncludeCorrelationIdTag": true,
          "CorrelationIdTagName": "http.correlation_id"
        }
      },

      "HttpClient": {
        "RecordException": true
      },

      "EntityFrameworkCore": {
        "Enabled": true,
        "EmitDbStatement": false
      },

      "Exporter": {
        "Otlp": {
          "Enabled": true,
          "Endpoint": "http://localhost:4317",
          "Protocol": "grpc",
          "Headers": ""
        },
        "Console": {
          "Enabled": false
        }
      }
    },

    "Metrics": {
      "Enabled": true,

      "AspNetCore": { "Enabled": true },
      "HttpClient": { "Enabled": true },
      "Runtime": { "Enabled": true },
      "Process": { "Enabled": true },

      "Meters": [
        "BasketMetrics"
      ],

      "Exporter": {
        "Otlp": {
          "Enabled": true,
          "Endpoint": "http://localhost:4317",
          "Protocol": "grpc",
          "Headers": ""
        },
        "Console": {
          "Enabled": false
        }
      }
    }
  },

  "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4317",

  "Kafka": {
    "BootstrapServers": "localhost:29092",
    "DefaultTopic": "integration-events"
  },

  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\ProjectModels;Database=BasketServiceApp;Trusted_Connection=True;TrustServerCertificate=true;MultipleActiveResultSets=true"
  },

  "AllowedHosts": "*"
}